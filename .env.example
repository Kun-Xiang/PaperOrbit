# Required for encrypted per-browser OpenAI and Semantic Scholar sessions.
# Generate with: openssl rand -hex 32
PAPER_ORBIT_SESSION_SECRET=

# Optional model override for the privileged shared connection and legacy personal sessions.
# New personal connections choose their model in the Paper Orbit UI. The default is gpt-5.6.
OPENAI_MODEL=gpt-5.6

# Optional legacy/shared server key. Only OWNER/MANAGER may use it; readers never can.
# Exception: `npm run dev:local` treats the loopback development identity as the
# machine owner, so a self-hosted local deployment can chat with only this .env.
OPENAI_API_KEY=

# Optional OpenAI-compatible endpoint for the shared credential above.
# Production requires a public HTTPS origin; `npm run dev:local` additionally
# allows http://127.0.0.1 or http://localhost loopback services.
# An invalid value disables the shared credential instead of falling back.
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional legacy/shared metadata key. Only OWNER/MANAGER may use it.
# Readers can connect their own key in the Paper Orbit UI; arXiv itself needs no key.
SEMANTIC_SCHOLAR_API_KEY=
