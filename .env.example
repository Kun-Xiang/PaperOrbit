# Required for encrypted per-browser OpenAI and Semantic Scholar sessions.
# Generate with: openssl rand -hex 32
PAPER_ORBIT_SESSION_SECRET=

# Optional model override. The default is gpt-5.6.
OPENAI_MODEL=gpt-5.6

# Optional legacy/shared server key. Only OWNER/MANAGER may use it; readers never can.
OPENAI_API_KEY=

# Optional legacy/shared metadata key. Only OWNER/MANAGER may use it.
# Readers can connect their own key in the Paper Orbit UI; arXiv itself needs no key.
SEMANTIC_SCHOLAR_API_KEY=
