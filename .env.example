# Required for per-browser OpenAI API sessions. Generate with: openssl rand -hex 32
PAPER_ORBIT_SESSION_SECRET=

# Optional model override. The default is gpt-5.6.
OPENAI_MODEL=gpt-5.6

# Optional legacy/shared server key. Leave empty when every user should bring their own key.
OPENAI_API_KEY=

# Optional: raises Semantic Scholar request availability for recommendation signals.
SEMANTIC_SCHOLAR_API_KEY=
